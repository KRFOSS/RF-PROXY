###############################################################################
# HTTP Caching Server 예시 환경변수 (.env.example)
# 사용 방법 (PowerShell):
#   Copy-Item .env.example .env
# 또는 (cmd):
#   copy .env.example .env
#
# 필요한 값 수정 후 `cargo run` 실행. 시스템 환경변수와 .env 둘 다 지원.
###############################################################################

########################################
# 기본 서버 설정
########################################
# 서버가 바인딩할 주소:포트 (기본 127.0.0.1:8080)
LISTEN_ADDR=0.0.0.0:7878

# 업스트림(원본) 서버 베이스 URL (필수)
# 예: https://example.com  또는  http://127.0.0.1:9000
UPSTREAM_BASE=https://mirrors.tuna.tsinghua.edu.cn

# 캐시 디렉토리 경로
CACHE_DIR=cache

########################################
# 캐시 동작 설정
########################################
# 최대 캐시 크기 (바이트). (기본 5GB) 아래는 1GB 예시
MAX_CACHE_SIZE_BYTES=1073741824

# (명시적 Cache-Control 없을 때) 기본 TTL(초)
DEFAULT_TTL_SECS=300

# Eviction Policy (LRU | FIFO | SIZE | LRU_SIZE) - 기본 LRU
EVICTION_POLICY=LRU

########################################
# 캐시 전체 비우기 Cron (신규 기능)
########################################
# tokio-cron-scheduler 형식 (초 필드 포함 6필드, 선택적 연도 7필드)
# 형식: second  minute  hour  day-of-month  month  day-of-week [year]
# 비활성화: 0  (또는 빈 값)
# 예시:
#   매 30초마다:          */30 * * * * *
#   매 5분:               0 */5 * * * *
#   매 시 정각:           0 0 * * * *
#   매일 03:30:           0 30 3 * * *
#   매일 00:00:           0 0 0 * * *
#   매주 월요일 02:15:    0 15 2 * * 1
# 잘못된 표현식이면 시작 시 에러.
# 안전: cron 으로 전체 삭제 시 사전에 주기/백업 정책 고려.
CACHE_CLEAR_CRON=*/30 * * * * *

########################################
# 로깅
########################################
# tracing_subscriber EnvFilter 구문. 예: info,hyper=warn
RUST_LOG=info

########################################
# 추가 참고
########################################
# 1) CACHE_CLEAR_CRON 으로 전체 삭제를 걸어도 max size 초과시의 개별 eviction 로직은 그대로 동작.
# 2) Cron 으로 삭제 시 .vary 파일도 포함된 디렉토리 내 모든 파일을 제거합니다.
# 3) Cron 표현식 테스트는 짧은 주기(예: */10 * * * * *) 로 먼저 확인 후 운영값 적용 권장.
