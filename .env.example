############################################################
# HTTP Caching Server 환경 변수 예시 (.env.example)
# PowerShell 복사:
#   Copy-Item .env.example .env
# bash/cmd:
#   cp .env.example .env
# 필요한 것만 남기고 수정하세요.
############################################################

############################
# 필수
############################
# 업스트림(원본) 서버 베이스 URL (반드시 설정)
# 예: https://example.com  또는  http://127.0.0.1:9000
UPSTREAM_BASE=https://example.com

############################
# 서버 / 캐시 기본 설정
############################
# 서버 바인딩 주소:포트 (기본 127.0.0.1:8080)
LISTEN_ADDR=0.0.0.0:7878

# 캐시 루트 디렉토리
CACHE_DIR=cache

# 최대 캐시 크기 (bytes) 기본=5GB. 아래는 1GB 예시
MAX_CACHE_SIZE_BYTES=1073741824

# 기본 TTL(초) - 업스트림 응답이 max-age / s-maxage / Expires 를 주지 않을 때 사용
DEFAULT_TTL_SECS=300

# Eviction 정책: LRU | FIFO | SIZE | LRU_SIZE (기본: LRU)
EVICTION_POLICY=LRU

############################
# 캐시 전체 삭제 스케줄 (둘 다 0 또는 미설정이면 비활성화)
############################
# 1) Cron 표현식 (tokio-cron-scheduler). 예시는 Quartz 형식(초 필드 포함):
#    매 10분 0초: "0 0/10 * * * * *"
#    매 정시 0초: "0 0 * * * * *"
#    비활성화: 0 또는 빈값
CACHE_CLEAR_CRON=0

# 2) 간단 주기(초) 기반 전체 클리어. 0이면 비활성화.
#    예: 3600 -> 1시간마다 캐시 전체 삭제
CACHE_CLEAR_INTERVAL_SECS=0

############################
# 로깅
############################
# tracing EnvFilter 형식. 여러 모듈 레벨 조합 가능.
# 예: info,hyper=warn,http_caching_server=debug
RUST_LOG=info

############################
# 참고
############################
# - CACHE_CLEAR_CRON 과 CACHE_CLEAR_INTERVAL_SECS 는 동시에 설정 가능하며 독립 실행.
# - 지나치게 짧은 삭제 주기는 캐시 히트율을 떨어뜨립니다.
# - EVICTION_POLICY 는 용량 초과 시 제거 우선순위를 결정.
# - DEFAULT_TTL_SECS 는 HTTP 캐시 지시어가 없을 때만 적용.
############################
